# Pick one LLM provider and uncomment its key.

# Anthropic (default)
# ANTHROPIC_API_KEY=

# OpenRouter
# OPENROUTER_API_KEY=
# BROWSER_USE_MODEL=google/gemini-2.0-flash-exp:free

# OpenAI
# OPENAI_API_KEY=

# DeepSeek / Groq / Together
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# Google Gemini
# GOOGLE_API_KEY=

# Ollama (local)
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434

# Override default model (optional)
# BROWSER_USE_MODEL=

# Browser
HEADLESS=true
# PROXY_SERVER=http://user:pass@proxy:8080
# BROWSER_TASK_TIMEOUT=120
