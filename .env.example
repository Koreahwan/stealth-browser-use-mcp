# Default: no key is needed when your MCP client supports sampling/createMessage.
# Use the fallback providers below only for clients without sampling support,
# or when you want to force Wraith to use an explicit provider.
# WRAITH_LLM_PROVIDER=mcp-sampling

# Anthropic (default)
# ANTHROPIC_API_KEY=

# OpenRouter
# OPENROUTER_API_KEY=
# BROWSER_USE_MODEL=google/gemini-2.0-flash-exp:free

# OpenAI
# OPENAI_API_KEY=

# DeepSeek / Groq / Together
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# Google Gemini
# GOOGLE_API_KEY=

# Ollama (local)
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434

# Override default model (optional)
# BROWSER_USE_MODEL=

# Force a fallback provider instead of MCP sampling (optional)
# WRAITH_LLM_PROVIDER=openrouter

# Browser
HEADLESS=true
# PROXY_SERVER=http://user:pass@proxy:8080
# BROWSER_TASK_TIMEOUT=120
# BLOCK_RESOURCES=image,font,media

# Fingerprint (consistent profile reduces detection)
# BROWSER_LANG=en-US
# BROWSER_WINDOW_SIZE=1920,1080
# BROWSER_LOCALE=en-US
# BROWSER_TIMEZONE=America/New_York

# BrowserProfile policy/session/artifacts (optional; forwarded when supported)
# BROWSER_ALLOWED_DOMAINS=example.com,*.example.org
# BROWSER_PROHIBITED_DOMAINS=ads.example.com,trackers.test
# BROWSER_BLOCK_IP_ADDRESSES=true
# BROWSER_STORAGE_STATE=.wraith/storage-state.json
# BROWSER_USER_DATA_DIR=.wraith/user-data
# BROWSER_DOWNLOADS_PATH=.wraith/downloads
# BROWSER_RECORD_HAR_PATH=.wraith/session.har
# BROWSER_RECORD_VIDEO_DIR=.wraith/videos
# BROWSER_TRACES_DIR=.wraith/traces
# BROWSER_PERMISSIONS=clipboard-read,clipboard-write
# BROWSER_VIEWPORT=1366,768
# BROWSER_MINIMUM_WAIT_PAGE_LOAD_TIME=0.25
# BROWSER_WAIT_FOR_NETWORK_IDLE_PAGE_LOAD_TIME=0.5
# BROWSER_WAIT_BETWEEN_ACTIONS=0.1
