# Pick one LLM provider and uncomment its key.

# Anthropic (default, included)
# ANTHROPIC_API_KEY=

# OpenRouter — pip install 'stealth-browser-use-mcp[openai]'
# OPENROUTER_API_KEY=
# BROWSER_USE_MODEL=google/gemini-2.0-flash-exp:free

# OpenAI — pip install 'stealth-browser-use-mcp[openai]'
# OPENAI_API_KEY=

# DeepSeek / Groq / Together — same [openai] extra
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# Google Gemini — pip install 'stealth-browser-use-mcp[google]'
# GOOGLE_API_KEY=

# Ollama (local) — pip install 'stealth-browser-use-mcp[ollama]'
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434

# Override default model (optional)
# BROWSER_USE_MODEL=

# Browser
HEADLESS=true
